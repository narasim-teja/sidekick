# ──────────────────────────────────────────────────────────────────────────────
# SideKick Perps — environment
#
# Copy to `.env` and fill in section 1. Section 2 is your config choices (oracle +
# markets). Section 3 is advanced overrides — leave it commented; the code already
# has working defaults for everything in it.
#
# NEVER commit `.env` (it is gitignored). Only this `.env.example` is tracked.
# DO NOT wrap values in quotes (except STORK_API_KEY, which is a Basic-auth blob).
# ──────────────────────────────────────────────────────────────────────────────


# ═══ 1. FILL THESE ════════════════════════════════════════════════════════════

# The venue OPERATOR / deployer key — a funded Arc-testnet account (gas = USDC). Used to deploy + run
# the venue and by the SDK Gateway top-up tool (packages/sdk/scripts/fund-gateway-for.ts). This is NOT
# an agent key — the demo agents sign through Circle wallets (section below). Fund it at
# https://faucet.circle.com. Use a throwaway hackathon key — NEVER one holding real funds.
PRIVATE_KEY=

# Stork oracle REST key (for live mark pushes). Get it from Stork; it's a Basic-auth blob.
STORK_API_KEY=

# Chainlink Data Streams credentials (Key ID + Secret from the Data Streams dashboard).
# Only needed if any market uses ORACLE_SOURCE=chainlink (see section 2). The CRE markfeed workflow
# also reads these (via secrets.yaml) to authenticate its Data Streams REST fetch.
CHAINLINK_API_KEY=
CHAINLINK_API_SECRET=
# Key the CRE CLI uses to submit the forwarder tx during `cre workflow simulate --broadcast`
# (any funded Arc EOA; the deploy/owner key is fine). Without it the CLI errors "CRE_ETH_PRIVATE_KEY is not set".
CRE_ETH_PRIVATE_KEY=

# Optional: your own Alchemy Arc RPC URL (faster than the public endpoint). Leave blank
# to use Circle's public RPC. If set, it's used for the per-block reads automatically.
ALCHEMY_ARC_RPC_URL=

# Circle developer-controlled wallet — the ONLY custody path for the MCP server, the standalone
# example, and the demo agent fleet (MPC, no seed/raw key in-process). These three sign through Circle
# wallets exclusively (gas-free margin calls included); there is no HD/raw-key fallback. The ENTITY
# SECRET is a SECRET — never commit it.
#   CIRCLE_API_KEY        from the Circle Console
#   CIRCLE_ENTITY_SECRET  32-byte hex; register its ciphertext once with the Console/SDK
#   CIRCLE_WALLET_ID      single wallet for the MCP server / the standalone example (from createWallets)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_ID=
# Demo fleet → Circle wallets (REQUIRED to run `bun run fund` / `demo` / `agent:*`): map the 5 roles to
# wallet ids, either as one ordered comma list (long,short,mm,funding,dark) or per-role
# CIRCLE_WALLET_ID_LONG / _SHORT / _MM / _FUNDING / _DARK. Fund each wallet's address from the faucet.
# CIRCLE_AGENT_WALLET_IDS=
# Create a set + 5 wallets: cd packages/sdk && bun run circle:wallets --name sidekick-agents --count 5


# ═══ 2. YOUR CONFIG CHOICES ═══════════════════════════════════════════════════

# Which markets to run: a comma list or "all". The engine AND the deploy script read this, so they
# always agree. The live demo set is 4 markets, all with a REAL on-chain mark, split across both oracles:
#   ETH/LINK → Chainlink Data Streams via CRE   ·   BTC/XAU → Stork (engine pushes before each checkpoint)
# (SOL/HYPE stay deployed but idle — no real feed anywhere on testnet.)
MARKETS=ETH-PERP,LINK-PERP,BTC-PERP,XAU-PERP

# Mark-price source, PLUGGABLE per market — swap Stork↔Chainlink with no code change:
#   ORACLE_SOURCE            global default for every market (stork | chainlink)
#   ORACLE_SOURCE_<SYMBOL>   per-market override (dash-stripped: BTC-PERP → BTCPERP)
# Each market's on-chain adapter has a fixed source(), so the resolved source MUST match it or the
# engine's assertAdapterSource guard fails at boot. ETH/LINK = Chainlink MarkReceivers; BTC/XAU = StorkAdapters.
ORACLE_SOURCE=chainlink
ORACLE_SOURCE_BTCPERP=stork
ORACLE_SOURCE_XAUPERP=stork

# Checkpoint + the engine's inline Stork mark-push fire every N blocks (not every block — gas; matches
# the docs' batched Layer-C). 5 ≈ every ~10s on Arc's ~2s blocks.
CHECKPOINT_EVERY_BLOCKS=5

# For any chainlink market, give its FIXED 32-byte Data Streams feed id (not derivable from the symbol —
# copy it from the Data Streams feed list), keyed CHAINLINK_FEED_<SYMBOL>. NOTE (testnet, verified via
# `bun run chainlink:probe`): only ETH/USD + LINK/USD return live reports on the testnet Data Streams
# engine. BTC/USD + SOL/USD 404 ("report not found"); HYPE has no Data Streams feed. Stork feed ids for
# BTC/XAU are derived (keccak256 of the asset), so no env needed for the Stork markets.
CHAINLINK_FEED_ETHPERP=0x000359843a543ee2fe414dc14c7e7920ef10f4372990b79d6361cdc0dd1ba782
CHAINLINK_FEED_LINKPERP=0x00036fe43f87884450b4c7e093cd5ed99cac6640d8c2000e6afc02c8838d0265
# BTC's feed id is valid format but 404s on this testnet account (kept for reference, not live):
# CHAINLINK_FEED_BTCPERP=0x00039d9e45394f473ab1f050a1b963e6b05351e52d71e507509ada0c95ed75b8


# ═══ 3. ADVANCED OVERRIDES (commented — leave as-is unless you know you need them) ═══
#
# Every var below already has the right default baked into the code. Uncomment a line
# ONLY to override that default.
#
# — Arc network (defaults to Circle's public endpoints) —
# ARC_RPC_URL=https://rpc.testnet.arc.network
# ARC_WSS_URL=wss://rpc.testnet.arc.network
# ARC_LOGS_RPC_URL=https://rpc.testnet.arc.network   # wide-range eth_getLogs (public RPC allows 10k blocks)
#
# — Oracle endpoints (defaults are the live Arc testnet addresses/hosts) —
# STORK_CONTRACT_ADDRESS=0xacC0a0cF13571d30B4b8637996F5D6D774d4fd62
# STORK_REST_URL=https://rest.jp.stork-oracle.network
# CHAINLINK_STREAMS_HOST=api.testnet-dataengine.chain.link
# Chainlink Data Streams Verifier proxy + fee token on Arc — UNCONFIRMED. Leave blank: the
# on-chain ChainlinkAdapter runs in relay mode (owner seeds marks) until these ship.
# CHAINLINK_VERIFIER=
# CHAINLINK_FEE_TOKEN=
#
# — Deploy (forge script script/Deploy.s.sol) —
# USDC_ADDRESS=0x3600000000000000000000000000000000000000   # canonical Arc USDC; unset → local test token
# OWNER_ADDRESS=                                             # multisig/timelock owner; unset → deployer EOA
# ARCSCAN_API_KEY=                                           # only for a --verify deploy run
#
# — Chainlink CRE forwarders (DeployCreVenue.s.sol; the consumers allowlist both) —
# The production Arc KeystoneForwarder (from `cre workflow supported-chains`) and the local CRE
# simulator forwarder, so `cre workflow simulate --broadcast` lands a real write. Both have script
# defaults; set here only to override (e.g. if Chainlink rotates the forwarder).
# CHAINLINK_FORWARDER=0x76c9cf548b4179F8901cda1f8623568b58215E62
# CRE_SIM_FORWARDER=0x6E9EE680ef59ef64Aa8C7371279c27E496b5eDc1
#
# — Engine + demo agents —
# ENGINE_PORT=8787
# CHECKPOINT_EVERY_BLOCKS=1            # checkpoint every N blocks (1 = every block)
# ENGINE_URL=http://localhost:8787     # base URL the SDK/agents connect to
# AGENT_MARKET=BTC-PERP                # market the demo agents trade
# DEFAULT_MARKET=BTC-PERP              # fallback market for spikes/scripts
#
# — Synthetic-mark demo tuning (make a fallback market visibly drift on camera) —
# SYNTH_DRIFT_PER_BLOCK=-0.0015
# SYNTH_VOL_PER_BLOCK=0.0015
#
# — Dashboard (apps/web, Phase 7) — NEXT_PUBLIC_* are inlined at build time —
# NEXT_PUBLIC_ENGINE_URL=http://localhost:8787   # engine REST base the dashboard reads (live mode)
# NEXT_PUBLIC_ENGINE_WS=ws://localhost:8787/ws   # WS stream (derived from the URL if unset)
# NEXT_PUBLIC_AGENTS={"0x..":"long","0x..":"dark"} # address→role labels for the live fleet, so the
#                                                  # dashboard names each Circle wallet's address by role
#                                                  # (map your CIRCLE_WALLET_ID_* wallet addresses here)
