# ──────────────────────────────────────────────────────────────────────────────
# SideKick Perps — environment template
#
# Copy to `.env` and fill in the SECRETS (private key, Alchemy URL, Stork API key).
# Everything else has a working public default and rarely needs changing.
# NEVER commit `.env` (it is gitignored). Only this `.env.example` is tracked.
# ──────────────────────────────────────────────────────────────────────────────

# ── Secrets (REQUIRED for the spikes) ─────────────────────────────────────────
# A funded Arc-testnet account. Fund it at https://faucet.circle.com (gas = USDC).
# Use a throwaway hackathon key — never a key holding real funds.
PRIVATE_KEY=

# ── Arc Testnet (chain 5042002) ───────────────────────────────────────────────
# Default RPC/WSS are Circle's public endpoints. To use Alchemy instead, paste the
# Alchemy Arc endpoint into ARC_RPC_URL (and the wss:// form into ARC_WSS_URL).
ARC_CHAIN_ID=5042002
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_WSS_URL=wss://rpc.testnet.arc.network
ARC_EXPLORER_URL=https://testnet.arcscan.app
# Optional: drop in your Alchemy Arc testnet URL here, then point ARC_RPC_URL at it.
ALCHEMY_ARC_RPC_URL=

# ── Oracles (mark price sources, behind the pluggable adapter) ─────────────────
# Stork (pull-based) — contract is the same for everyone on Arc testnet.
STORK_CONTRACT_ADDRESS=0xacC0a0cF13571d30B4b8637996F5D6D774d4fd62
# Stork REST API (to fetch signed price updates). Get a key from Stork; Basic auth.
STORK_REST_URL=https://rest.jp.stork-oracle.network
STORK_API_KEY=
# Chainlink — Data Feeds / Data Streams addresses on Arc are filled per-asset once
# verified Day-1 (Spike B). Leave blank until confirmed.
CHAINLINK_FEED_BTC_USD=
CHAINLINK_FEED_ETH_USD=

# ── Circle Gateway (nanopayments / Layer B) ───────────────────────────────────
# The @circle-fin/x402-batching SDK uses chain alias "arcTestnet"; addresses below
# are the raw-contract fallback (Spike C resolves which surface we use).
GATEWAY_CHAIN_ALIAS=arcTestnet
GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_MINTER_ADDRESS=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B
GATEWAY_ARC_DOMAIN_ID=26

# ── Misc ──────────────────────────────────────────────────────────────────────
# Default market the spikes / engine operate on when not specified.
DEFAULT_MARKET=ETH-PERP
