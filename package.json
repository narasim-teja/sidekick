{
  "name": "sidekick",
  "private": true,
  "version": "0.0.0",
  "description": "SideKick Perps — an agent-native perpetual futures venue on Arc with per-block funding, no liquidations, and gas-free nanopayment settlement.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "spike:arc": "bun run packages/contracts/spikes/a-arc-deploy.ts",
    "spike:oracle": "bun run packages/contracts/spikes/b-oracle-read.ts",
    "spike:gateway": "bun run packages/contracts/spikes/c-gateway-roundtrip.ts",
    "spikes": "bun run spike:arc && bun run spike:oracle && bun run spike:gateway",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "sim": "bun run --filter '@sidekick/engine' sim",
    "engine": "bun run --filter '@sidekick/engine' dev",
    "web": "bun run --filter '@sidekick/web' dev",
    "web:build": "bun run --filter '@sidekick/web' build",
    "fund": "bun run --filter '@sidekick/agents' fund",
    "reset": "bun run --filter '@sidekick/agents' reset",
    "demo": "bun run --filter '@sidekick/agents' demo",
    "agent:payer": "bun run --filter '@sidekick/agents' agent:payer",
    "example": "bun run examples/standalone-agent.ts",
    "mcp": "bun run --filter '@sidekick/mcp' start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
