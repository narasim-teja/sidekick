{
  "name": "@sidekick/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "@sidekick/engine — the off-chain per-block loop. Layer A (mark/fund/solvency/decrement compute) + Layer B (Gateway nanopayment authorizations). Doubles as the Phase 1 economic simulation. Built in Phases 1 & 3.",
  "exports": {
    ".": "./src/index.ts",
    "./fixed/units": "./src/fixed/units.ts",
    "./state": "./src/state.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "sim": "bun run src/sim/index.ts",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "live:tick": "bun run src/scripts/live-tick.ts",
    "live:open": "bun run src/scripts/live-open.ts",
    "chainlink:probe": "bun run src/scripts/chainlink-probe.ts"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "3.0.4",
    "@sidekick/shared": "workspace:*",
    "@x402/core": "2.15.0",
    "@x402/evm": "2.15.0",
    "hono": "4.12.25",
    "viem": "2.52.2"
  }
}
