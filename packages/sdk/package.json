{
  "name": "@sidekick/sdk",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "@sidekick/sdk — the agent-facing TypeScript client: read state, act (open/close, post/withdraw collateral, provide liquidity, answer margin calls), and subscribe to the per-block event stream. The venue from the consumer's POV (Doc 2 Phase 5).",
  "exports": {
    ".": "./src/index.ts",
    "./keys": "./src/keys.ts",
    "./abis": "./src/abis.ts",
    "./circle": "./src/circle-account.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "verify:circle": "bun run scripts/verify-circle.ts",
    "circle:wallets": "bun run scripts/create-sidekick-wallets.ts"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "10.6.0",
    "@circle-fin/x402-batching": "3.0.4",
    "@sidekick/engine": "workspace:*",
    "@sidekick/shared": "workspace:*",
    "@x402/core": "2.15.0",
    "viem": "2.52.2"
  }
}
